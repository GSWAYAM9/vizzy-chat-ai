# Vizzy Chat AI - Environment Variables
# Copy this file to .env.local and fill in your actual API keys

# ==========================================
# REQUIRED - AI Service Keys
# ==========================================

# Groq API Key (for chat and image analysis)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Runware API Key (for image generation - PRIMARY IMAGE GENERATION SERVICE)
# Get from: https://www.runware.ai
RUNWARE_API_KEY=your_runware_api_key_here

# Stability API Key (for image inpainting/editing)
# Get from: https://platform.stability.ai
STABILITY_API_KEY=your_stability_api_key_here

# ==========================================
# OPTIONAL - Backend Configuration
# ==========================================

# Backend URL (for gallery, batch processing, analytics)
# Default: http://localhost:8000
# For production: https://your-backend-domain.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ==========================================
# OPTIONAL - Development Settings
# ==========================================

# Node environment
NODE_ENV=development

# Enable debug logging
DEBUG=true
